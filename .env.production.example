# TicketLens — Production Environment Template
# Copy this to .env, fill in all values marked <REQUIRED>, then run ./scripts/deploy.sh
# Never commit the real .env to version control.

# -------------------------------------------------------------------------
# Application
# -------------------------------------------------------------------------
APP_NAME=TicketLens
APP_ENV=production
APP_KEY=<REQUIRED — run: php artisan key:generate --show>
APP_DEBUG=false
APP_URL=https://your-domain.com          # <REQUIRED — no trailing slash>
APP_VERSION=1.0.0

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

# -------------------------------------------------------------------------
# Database (MySQL)
# -------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=mysql                            # Docker service name — keep as-is
DB_PORT=3306
DB_DATABASE=ticketlens                   # <REQUIRED>
DB_USERNAME=ticketlens                   # <REQUIRED — non-root user>
DB_PASSWORD=<REQUIRED>
DB_ROOT_PASSWORD=<REQUIRED — root password for the MySQL container>

# -------------------------------------------------------------------------
# Redis (cache, sessions, queues)
# -------------------------------------------------------------------------
REDIS_CLIENT=phpredis
REDIS_HOST=redis                         # Docker service name — keep as-is
REDIS_PORT=6379
REDIS_PASSWORD=<REQUIRED — set a strong password>

CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
QUEUE_CONNECTION=redis

# -------------------------------------------------------------------------
# Broadcasting (Reverb) — the `reverb` container reads these three directly
# -------------------------------------------------------------------------
REVERB_APP_ID=<REQUIRED — any random string, e.g. `openssl rand -hex 16`>
REVERB_APP_KEY=<REQUIRED — any random string, e.g. `openssl rand -hex 20`>
REVERB_APP_SECRET=<REQUIRED — any random string, e.g. `openssl rand -hex 20`>

# -------------------------------------------------------------------------
# Mail
# -------------------------------------------------------------------------
MAIL_MAILER=smtp                         # or: ses, mailgun, postmark
MAIL_HOST=<REQUIRED>
MAIL_PORT=587
MAIL_USERNAME=<REQUIRED>
MAIL_PASSWORD=<REQUIRED>
MAIL_SCHEME=tls
MAIL_FROM_ADDRESS=noreply@your-domain.com  # <REQUIRED>
MAIL_FROM_NAME=TicketLens

# -------------------------------------------------------------------------
# TLS / nginx (paths inside the container, mounted as volumes)
# -------------------------------------------------------------------------
SSL_CERT_PATH=/etc/ssl/certs/ticketlens.crt    # host path to your cert
SSL_KEY_PATH=/etc/ssl/private/ticketlens.key   # host path to your key

# -------------------------------------------------------------------------
# Logging
# -------------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_LEVEL=warning                        # error | warning | info | debug

# -------------------------------------------------------------------------
# TicketLens application keys
# -------------------------------------------------------------------------
# License key signing secret — must match what LemonSqueezy uses to sign webhooks
LEMON_SQUEEZY_WEBHOOK_SECRET=<REQUIRED>
# Skip license check in local dev only (never set to true in production)
TICKETLENS_SKIP_LICENSE=false

# -------------------------------------------------------------------------
# Misc
# -------------------------------------------------------------------------
BCRYPT_ROUNDS=12
FILESYSTEM_DISK=local
BROADCAST_CONNECTION=reverb
